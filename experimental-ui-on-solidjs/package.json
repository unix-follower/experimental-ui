{
  "name": "vite-template-solid",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "check-format": "prettier --log-level error --check '**/*.{js,jsx,ts,tsx,cjs,mjs,json,css,html}'",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,cjs,mjs,json,css,html}'"
  },
  "license": "MIT",
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.5",
    "solid-devtools": "^0.34.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.1.4",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "solid-js": "^1.9.5"
  },
  "overrides": {
    "eslint-plugin-solid": {
      "eslint": "$eslint"
    }
  }
}
