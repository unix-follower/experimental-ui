{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "allowJs": true,
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "/public/*": ["./public/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
